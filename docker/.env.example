# Web server
ENABLE_WEBSERVER=true
WEBSERVER_PORT=8080
WEBSERVER_WATCHDOG=true
WEBSERVER_WATCHDOG_INTERVAL=60

# Notification channels
FEISHU_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DINGTALK_WEBHOOK_URL=
WEWORK_WEBHOOK_URL=
WEWORK_MSG_TYPE=
EMAIL_FROM=
EMAIL_PASSWORD=
EMAIL_TO=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=
NTFY_SERVER_URL=
NTFY_TOPIC=
NTFY_TOKEN=
BARK_URL=
SLACK_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=
GENERIC_WEBHOOK_TEMPLATE=

# AI runtime. Put real secrets only in docker/.env on the target host.
AI_ANALYSIS_ENABLED=true
AI_API_KEY=
AI_MODEL=openai/gpt-5.4
AI_API_BASE=
AI_FALLBACK_API_KEY=
AI_FALLBACK_MODEL=openai/gpt-5.4
AI_FALLBACK_API_BASE=
AI_FORCE_STREAM=true
AI_AUTO_STREAM_FALLBACK=true
AI_USE_RESPONSES_API=true
AI_MIN_REQUEST_INTERVAL_SECONDS=5

# RSS host bridge
RSS_AGENT_VIEWER_API_BASE=http://host.docker.internal:18789

# Remote storage
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# Runtime
CRON_SCHEDULE=0 0 1 1 1
RUN_MODE=cron
IMMEDIATE_RUN=false
